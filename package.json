{
  "name": "talisman-forge",
  "version": "0.1.0",
  "description": "Talisman Forge desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:dir": "electron-builder --dir",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.digitaltalisman.forge",
    "productName": "Talisman Forge",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.productivity",
      "minimumSystemVersion": "12.0"
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}